{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ProblemDetails": {
    "IncludeExceptionMessages": true,
    "IncludeTraceId": true,
    "SupportUrl": "https://localhost/docs/errors"
  },
  "LlmPrompts": {
    "GenerateTopics": {
      "Instructions": "Generate a logical learning path of topic titles.",
      "OutputRules": [
        "Return ONLY valid JSON",
        "Do not include any text before or after the JSON",
        "No explanations",
        "No markdown",
        "No greetings",
        "The JSON must be parseable",
        "If you cannot, return an empty JSON object"
      ],
      "OutputFormat": {
        "type": "object",
        "schema": {
          "topics": ["string"]
        }
      },
      "OutputExample": {
        "topics": [
          "Introduction to C#",
          "Variables and Data Types",
          "Control Flow",
          "Object-Oriented Programming",
          "LINQ Basics"
        ]
      },
      "MinTopics": 5,
      "MaxTopics": 10
    }
  }
}
